# PixelWars Backend Environment Variables

# Neon PostgreSQL - Pooled connection (for app runtime)
DATABASE_URL="postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_ENDPOINT-pooler.YOUR_REGION.aws.neon.tech/neondb?sslmode=require"

# Neon PostgreSQL - Direct connection (for migrations/CLI)
DIRECT_URL="postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_ENDPOINT.YOUR_REGION.aws.neon.tech/neondb?sslmode=require"

# Server
PORT=4000
FRONTEND_URL=http://localhost:5173
